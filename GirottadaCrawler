typedef struct {
    int x, y;
    char dir;
    int hp;
    int arma;
    int chaves; 
} player;

// Limpar ataque estendido para suportar a matriz máxima de 25x25
void limparAtaque(char ataque[25][25]) {
    for(int y=0; y<25; y++) {
        for(int x=0; x<25; x++) {
            ataque[y][x] = ' ';
        }
    }
}


void atacar(player *p, char mapa[25][25], char ataque[25][25], int tamanho) {
    int x_alvo, y_alvo;
    if (p->arma == 0) {
        printf("Você precisa pegar uma arma com o NPC primeiro!\n");
        system("pause");
        return;
    }
    if (p->arma == 1) {
        int i;
        for (i = 1; i <= 2; i++) {
            for (int j = -1; j <= 1; j++) {
                if (p->dir == '^') { x_alvo = p->x + j; y_alvo = p->y - i; } 
                else if (p->dir == 'v') { x_alvo = p->x + j; y_alvo = p->y + i; } 
                else if (p->dir == '<') { x_alvo = p->x - i; y_alvo = p->y + j; } 
                else if (p->dir == '>') { x_alvo = p->x + i; y_alvo = p->y + j; }
                
                if (x_alvo >= 0 && x_alvo < tamanho && y_alvo >= 0 && y_alvo < tamanho) {
                    ataque[y_alvo][x_alvo] = 'z';
                    if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                        mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                        mapa[y_alvo][x_alvo] = ' ';
                    }
                }
            }
        }
    }
    else if (p->arma == 2) {
        for (int i = 1; i <= 4; i++) {
            if (p->dir == '^') { x_alvo = p->x; y_alvo = p->y - i; }
            else if (p->dir == 'v') { x_alvo = p->x; y_alvo = p->y + i; }
            else if (p->dir == '<') { x_alvo = p->x - i; y_alvo = p->y; }
            else if (p->dir == '>') { x_alvo = p->x + i; y_alvo = p->y; }
            
            if (x_alvo >= 0 && x_alvo < tamanho && y_alvo >= 0 && y_alvo < tamanho) {
                ataque[y_alvo][x_alvo] = 'z';
                if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                    mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                    mapa[y_alvo][x_alvo] = ' ';
                }
            }
        }
    }
    else if (p->arma == 3) {
        for (int dy = -1; dy <= 1; dy++) {
            for (int dx = -1; dx <= 1; dx++) {
                if (dx == 0 && dy == 0) continue;
                x_alvo = p->x + dx;
                y_alvo = p->y + dy;
                if (x_alvo >= 0 && x_alvo < tamanho && y_alvo >= 0 && y_alvo < tamanho) {
                    ataque[y_alvo][x_alvo] = 'z';
                    if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                        mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                        mapa[y_alvo][x_alvo] = ' ';
                    }
                }
            }
        }
    }
}


void npc(player *p) {
    int escolha;
    printf("Olá aventureiro, seja bem vindo aqui em Girottinho! veio enfrentar a masmorra? ela está ao sul! porém não vá desprotegido... pegue uma dessas armas:\n");
    printf("1 - Espada\n");
    printf("2 - Arco\n");
    printf("3 - cajado\n");
    scanf("%d", &escolha);
    switch(escolha) {
        case 1: p->arma = 1; printf("Voce recebeu uma Espada!\n"); break;
        case 2: p->arma = 2; printf("Voce recebeu um Arco!\n"); break;
        case 3: p->arma = 3; printf("Voce recebeu um Cajado!\n"); break;
    }
    system("pause");
}


int tangivel(char mapa[25][25], int x, int y) {
    switch(mapa[y][x]) {
        case '*':
        case 'N':
        case 'D':
        case 'k':
            return 0;
        default:
            return 1;
    }
}


void mover(player *p, char tecla) {
    switch (tecla) {
        case 'w': p->y--; p->dir = '^'; break;
        case 's': p->y++; p->dir = 'v'; break;
        case 'a': p->x--; p->dir = '<'; break;
        case 'd': p->x++; p->dir = '>'; break;
    }
}


void desenharmapa(char mapa[25][25], char ataque[25][25], player jogador, int tamanho) {
    int x, y;
    printf("VIDAS: %d | CHAVES: %d | ARMA: %s\n", jogador.hp, jogador.chaves, 
           jogador.arma == 1 ? "Espada" : (jogador.arma == 2 ? "Arco" : (jogador.arma == 3 ? "Cajado" : "Nenhuma")));
    for(y = 0; y < tamanho; y++) {
        for(x = 0; x < tamanho; x++) {
            if(x == jogador.x && y == jogador.y)
                printf("%c", jogador.dir);
            else if(ataque[y][x] == 'z')
                printf("z");
            else
                printf("%c", mapa[y][x]);
        }
        printf("\n");
    }
}

